<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base theme used only for the splash / pre-Compose window. Compose drives real theming. -->
    <style name="Theme.MiCaSong.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_seed</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MiCaSong</item>
    </style>

    <style name="Theme.MiCaSong" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>
</resources>
